\import Function

\record IsoProof {A B : \Type} (f : A -> B) {
  \func Injective => \Pi (a a' : A) -> f a = f a' -> a = a'

  \func Surjective => \Pi (b : B) -> \Sigma (a : A) (f a = b)

  \func Bijective => \Sigma Injective Surjective

  \func Is_iso => \Sigma (g : B -> A) (f o g = id) (g o f = id)
}